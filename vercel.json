{
  "builds": [
    {
      "src": "smart_transport/smart_transport/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "smart_transport/smart_transport/wsgi.py"
    }
  ]
}
